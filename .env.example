LLM_API_KEY=your_api_key_here
LLM_BASE_URL=
LLM_MODEL=
# Keep tiny for the current default workflow.
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# For English videos, setting SOURCE_LANGUAGE=en usually keeps the original text
# closer to the audio. Bilingual subtitles render Chinese on line 1 and the
# original English on line 2.
SOURCE_LANGUAGE=
TRANSLATION_BATCH_SIZE=12
OUTPUT_DIR=output
